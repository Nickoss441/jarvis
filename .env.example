# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Core Configuration
ANTHROPIC_MODEL=claude-sonnet-4-6
JARVIS_DEPLOYMENT_TARGET=laptop
JARVIS_VOICE_STACK=local
JARVIS_USER_NAME=User
JARVIS_NOTES_DIR=D:/jarvis-data/notes
JARVIS_AUDIT_DB=D:/jarvis-data/audit.db

# Optional phase toggles (false by default)
# JARVIS_PHASE_VOICE=false
#   Without this: voice wake-word detection, STT, and TTS are disabled.
#   Requires: JARVIS_VOICE_WAKE_WORD, JARVIS_VOICE_STT_PROVIDER, JARVIS_VOICE_TTS_PROVIDER
#   Breaks: Any voice-based monitor or input.
JARVIS_VOICE_WAKE_WORD=jarvis
JARVIS_VOICE_STT_PROVIDER=faster-whisper
JARVIS_VOICE_TTS_PROVIDER=piper
# Optional real TTS backend settings for hosted providers like ElevenLabs.
JARVIS_VOICE_TTS_MODEL=eleven_multilingual_v2
JARVIS_VOICE_TTS_DEFAULT_VOICE=male
JARVIS_VOICE_TTS_VOICE_ID_MALE=
JARVIS_VOICE_TTS_VOICE_ID_FEMALE=
JARVIS_VOICE_TTS_VOICE_ID_EVA=
JARVIS_VOICE_TTS_FALLBACK_PROVIDER=piper
# ELEVENLABS_API_KEY=

# JARVIS_PHASE_SMART_HOME=false
#   Without this: Home Assistant integration and smart-home controls are disabled.
#   Requires: JARVIS_HOME_ASSISTANT_URL, JARVIS_HOME_ASSISTANT_TOKEN
#   Breaks: home_assistant read/write tools, any automation rules for lights/locks/climate.

# JARVIS_PHASE_APPROVALS=false
#   Without this: Approval gate system is disabled; gated tools run immediately without human sign-off.
#   Required by: JARVIS_PHASE_PAYMENTS, JARVIS_PHASE_TELEPHONY, JARVIS_PHASE_TRADING
#   Breaks: message_send, call_phone, payments, and trade gated tools (will be stubbed).
#   Consequences: Dangerous — gated operations will execute without approval.

# JARVIS_PHASE_PAYMENTS=false
#   Without this: Payment execution and budget tracking are disabled.
#   Requires: JARVIS_PHASE_APPROVALS=true, JARVIS_PAYMENTS_LEDGER
#   Breaks: payments tool (will be stubbed).

# JARVIS_PHASE_TELEPHONY=false
#   Without this: Outbound calling and telephony features are disabled.
#   Requires: JARVIS_PHASE_APPROVALS=true, JARVIS_TELEPHONY_CALLER_ID, JARVIS_TELEPHONY_PROVIDER
#   Breaks: call_phone tool (will be stubbed), call-time recording/transcription.

# JARVIS_PHASE_TRADING=false
#   Without this: Trading execution (paper and live) is disabled.
#   Requires: JARVIS_PHASE_APPROVALS=true, trading broker credentials (ALPACA_API_KEY, etc.)
#   Breaks: trade tool (will be stubbed), portfolio analysis.

# Gated Tool Configuration (approval/dry-run modes)
# All gated tools start in dry_run mode by default for safety.
# Progressing to approval/live modes requires JARVIS_PHASE_APPROVALS=true and tool-specific setup.

# Outbound messaging tool (first gated integration)
#   Requires: JARVIS_PHASE_APPROVALS=true for approval_required mode
#   Breaks without: Messaging functionality; tool becomes a stub.
JARVIS_MESSAGE_SEND_MODE=dry_run
JARVIS_MESSAGE_OUTBOX=D:/jarvis-data/message-outbox.jsonl

# Outbound calling tool (second gated integration)
#   Requires: JARVIS_PHASE_APPROVALS=true, JARVIS_TELEPHONY_CALLER_ID, JARVIS_TELEPHONY_PROVIDER
#   Breaks without: Calling functionality; tool becomes a stub.
JARVIS_CALL_PHONE_MODE=dry_run
JARVIS_CALLS_LOG_PATH=D:/jarvis-data/calls-log.jsonl

# Payments tool (third gated integration)
#   Requires: JARVIS_PHASE_APPROVALS=true, JARVIS_PHASE_PAYMENTS=true
#   Breaks without: Payments functionality; tool becomes a stub; budget controls disabled.
JARVIS_PAYMENTS_MODE=dry_run
JARVIS_PAYMENTS_LEDGER=D:/jarvis-data/payments-ledger.jsonl
JARVIS_PAYMENTS_BUDGET_DB=D:/jarvis-data/payments-budget.db
# Virtual-card budget controls
JARVIS_PAYMENTS_MONTHLY_CAP=10000
JARVIS_PAYMENTS_TX_LIMIT=10000
# Optional MCC allowlist (comma-separated), e.g. groceries + restaurants
JARVIS_PAYMENTS_ALLOWED_MCCS=
# Reconciliation webhook HMAC secret (required for /payments/reconcile)
JARVIS_PAYMENTS_WEBHOOK_SECRET=

# Trading tool (fourth gated integration)
#   Requires: JARVIS_PHASE_APPROVALS=true, JARVIS_PHASE_TRADING=true
#   Breaks without: Trading functionality; tool becomes a stub; paper/live modes disabled.
JARVIS_TRADES_MODE=dry_run
JARVIS_TRADES_LOG=D:/jarvis-data/trades-log.jsonl
# Chosen project default paper broker: alpaca (other options include fxopen/ibkr)
JARVIS_TRADING_PAPER_BROKER=alpaca

# Approval Gate System Configuration
# Core approval infrastructure for all gated tool operations.

JARVIS_APPROVAL_DB=D:/jarvis-data/approvals.db
JARVIS_APPROVALS_TTL_SECONDS=900
JARVIS_APPROVALS_DISPATCH_COOLDOWN_SECONDS=0
JARVIS_APPROVALS_DISPATCH_MAX_PER_RUN=25
# Optional per-kind cooldown map, comma-separated: kind:seconds
# Example: message_send:60,trade:300
JARVIS_APPROVALS_DISPATCH_COOLDOWN_BY_KIND=
JARVIS_APPROVALS_API_HOST=127.0.0.1
JARVIS_APPROVALS_API_PORT=8080
# Chosen project default approval channel: ntfy (other options include pushover/sms/app)
JARVIS_APPROVAL_CHANNEL=ntfy

# Open Tool Configuration (no approval required)
# These tools are available by default and do not require gating.

JARVIS_CALENDAR_ICS=D:/jarvis-data/calendar.ics
JARVIS_MAIL_DRAFTS_PATH=D:/jarvis-data/mail-drafts.jsonl

# Perception Layer Configuration
# Event bus, monitors, and incoming webhook/vision listeners.

JARVIS_EVENT_BUS_DB=D:/jarvis-data/event-bus.db
JARVIS_DROPZONE_DIR=D:/jarvis-data/dropzone
# Optional RSS feed for monitor-run-once (supports file:// and https://)
JARVIS_RSS_FEED_URL=
JARVIS_WEBHOOK_HOST=127.0.0.1
JARVIS_WEBHOOK_PORT=9010
JARVIS_WEBHOOK_SOURCE=default
# Optional HMAC secret for incoming webhooks (header: X-Jarvis-Signature)
JARVIS_WEBHOOK_SECRET=
# Optional path->kind mapping (comma-separated): /github:webhook_github,/ifttt:webhook_ifttt
JARVIS_WEBHOOK_PATH_KIND_MAP=
# Vision ingest listener (iPhone/Ray-Ban bridge)
JARVIS_VISION_HOST=127.0.0.1
JARVIS_VISION_PORT=9021
JARVIS_VISION_SOURCE=iphone
# Optional HMAC secret for camera frame posts (header: X-Jarvis-Signature)
JARVIS_VISION_SECRET=
# Frame payload size cap in bytes (base64-decoded estimate)
JARVIS_VISION_MAX_FRAME_BYTES=2000000
# Optional: on Python 3.13+, set to 1/true/yes/on to force Apple Vision landmarks path
JARVIS_FORCE_VISION_LANDMARKS=
# Perception quality gates for automation alert inclusion
JARVIS_VISION_MIN_FACE_CONFIDENCE=0.8
JARVIS_VISION_MIN_COLOR_COVERAGE=0.8
JARVIS_EVENT_ALERT_CHANNEL=slack
JARVIS_EVENT_ALERT_RECIPIENT=#ops
# Optional per-kind hourly automation caps, comma-separated: kind:max_per_hour
# Example: webhook_github:10,filesystem_new_file:30
JARVIS_EVENT_ALERTS_MAX_PER_HOUR_BY_KIND=
JARVIS_EVENT_ACTIONS_RETENTION_DAYS=30

# Location-aware utility tools (`weather_now`, `route_eta`)
# dry_run: deterministic local estimates without external API calls
# live: use Open-Meteo + OSRM public APIs
JARVIS_LOCATION_TOOLS_MODE=dry_run

# Gold market data (`gold_price`)
# dry_run: deterministic mock spot price without external API calls
# live: use metals.live public API
JARVIS_GOLD_MARKET_MODE=dry_run

# News sentiment analysis (`news-sentiment`)
# dry_run: deterministic mock news feed without external API calls
# live: use NewsAPI or similar service (requires API key configuration)
JARVIS_NEWS_SENTIMENT_MODE=dry_run
# JARVIS_NEWS_API_KEY=  # Required for live news sentiment mode (NewsAPI.org)

# YouTube comment sentiment analysis (`youtube-sentiment`)
# dry_run: deterministic mock comment sentiment without external API calls
# live: use YouTube Data API v3 (requires API key configuration)
JARVIS_YOUTUBE_SENTIMENT_MODE=dry_run
# JARVIS_YOUTUBE_API_KEY=  # Required for live YouTube sentiment mode (YouTube Data API v3)

# Ollama (local LLM — optional fast path)
# dolphin3:8b is the recommended model for local inference on this machine.
# Run: ollama pull dolphin3:8b  (already installed as of 2026-04-30)
OLLAMA_BASE_URL=http://localhost:11434
JARVIS_OLLAMA_WARM_MODEL=dolphin3:8b
# JARVIS_OLLAMA_ENABLED=true
# JARVIS_OLLAMA_FAST_MODE=true
# JARVIS_OLLAMA_NUM_CTX=8192
# JARVIS_OLLAMA_NUM_PREDICT=256
# JARVIS_OLLAMA_KEEP_ALIVE=30m

# Third-Party Integrations
# API keys and credentials for external services.

# Blockchain/Solana (optional — for blockchain monitoring)
#   Breaks without: Solana transaction lookups and wallet activity monitoring disabled.
HELIUS_API_KEY=
HELIUS_NETWORK=mainnet

# Vision self-test summary env defaults (optional; CLI flags override)
JARVIS_SUMMARY_STRICT=
JARVIS_MAX_INVALID_LINES=
JARVIS_EMA_ALPHA=0.3
JARVIS_MAX_INVALID_LINE_RATE_DELTA=
JARVIS_MAX_INVALID_LINE_RATE_EMA=

# --------------------------------------------------------------------
