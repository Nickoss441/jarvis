# STRIPE_WEBHOOK_SECRET=

# Broker/trading providers
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# FXOPEN_API_KEY=

# Approval/push providers
# NTFY_TOPIC=
# PUSHOVER_APP_TOKEN=
# PUSHOVER_USER_KEY=

# Spotify (for playback control)
# Create an app at https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# SMTP email sending (for message_send live mode)
# JARVIS_SMTP_HOST=smtp.gmail.com
# JARVIS_SMTP_PORT=587
# JARVIS_SMTP_USER=you@gmail.com
# JARVIS_SMTP_PASS=your-app-password   # use Gmail App Password, not your real password
# JARVIS_SMTP_FROM=you@gmail.com
